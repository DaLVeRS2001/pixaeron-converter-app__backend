# Auth runtime environment. Paste this file's content into:
# Settings -> Environments -> production -> Environment secrets -> AUTH_RUNTIME_ENV
#
# This file is for documentation only. Do not commit real values.

DATABASE_URL=postgresql://USERNAME:URL_ENCODED_PASSWORD@PRIVATE_DB_ENDPOINT:5432/dbauth?schema=public&sslmode=verify-full&sslrootcert=/app/certs/global-bundle.pem

JWT_SECRET=GENERATE_A_LONG_RANDOM_VALUE
JWT_EXPIRATION_MS=900000
REFRESH_EXPIRATION_MS=604800000
SESSION_REFRESH_EXPIRATION_MS=86400000
REFRESH_TOKEN_HASH_ROUNDS=12
IP_HASH_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_VALUE

# Use 0 before Caddy/proxy and 1 after the reverse proxy starts forwarding requests.
TRUST_PROXY=0

CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_HOSTNAME=
CAPTCHA_MIN_SCORE=0

GOOGLE_CLIENT_ID=
